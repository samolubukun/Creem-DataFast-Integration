# Required: Your CREEM API key from https://creem.io/dashboard
CREEM_API_KEY=your_creem_api_key_here

# Required: Your CREEM product ID
CREEM_PRODUCT_ID=prod_your_product_id_here

# Required: Your DataFast API key from https://datafa.st
DATAFAST_API_KEY=your_datafast_api_key_here

# Optional: CREEM webhook secret for signature verification
# Found in Dashboard > Developers > Webhooks
CREEM_WEBHOOK_SECRET=your_creem_webhook_secret_here

# Optional: Server port
PORT=3000
