{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "paths": {
      "creem-datafast-integration": ["../../src/index.ts"],
      "creem-datafast-integration/express": ["../../src/gateways/express.ts"],
      "creem-datafast-integration/next": ["../../src/gateways/next.ts"],
      "creem-datafast-integration/idempotency/*": ["../../src/storage/*.ts"],
      "creem-datafast-integration/client": ["../../src/browser/tracking.ts"],
      "creem-datafast-integration/server": ["../../src/engine/webhooks.ts"]
    }
  },
  "include": ["src/**/*"]
}
