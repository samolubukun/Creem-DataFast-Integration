{
  "name": "creem-datafast-integration",
  "version": "2.0.0",
  "description": "TypeScript package that connects CREEM payments to DataFast analytics for revenue attribution",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js"
    },
    "./express": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js"
    },
    "./nextjs": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js"
    },
    "./idempotency/upstash": {
      "types": "./dist/utils/idempotency-upstash.d.ts",
      "import": "./dist/utils/idempotency-upstash.mjs",
      "require": "./dist/utils/idempotency-upstash.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "creem",
    "datafast",
    "payments",
    "analytics",
    "attribution",
    "revenue",
    "webhooks"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "creem": "^1.0.0"
  },
  "optionalDependencies": {
    "@upstash/redis": "^2.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "next": "^16.1.6",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "@upstash/redis": {
      "optional": true
    }
  }
}
