{
  "name": "creem-datafast-integration",
  "version": "2.1.4",
  "description": "Premium wrapper for Creem SDK to capture DataFast attribution and handle webhooks with idempotency and hydration.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    },
    "./idempotency/upstash": {
      "types": "./dist/idempotency/upstash.d.ts",
      "import": "./dist/idempotency/upstash.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke:webhook": "node scripts/smoke-webhook.mjs"
  },
  "keywords": [
    "creem",
    "datafast",
    "payments",
    "analytics",
    "attribution",
    "revenue",
    "webhooks",
    "nextjs",
    "express"
  ],
  "license": "MIT",
  "dependencies": {
    "creem": "^1.4.2",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@upstash/redis": "^1.37.0",
    "express": ">=4.0.0",
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "@upstash/redis": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@upstash/redis": "^1.37.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  }
}
